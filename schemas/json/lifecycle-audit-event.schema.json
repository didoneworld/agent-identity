{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "subject_type",
    "subject_id",
    "timestamp",
    "evidence_hash"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "subject_type": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "previous_state": {
      "type": [
        "string",
        "null"
      ]
    },
    "new_state": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor_type": {
      "type": "string"
    },
    "actor_id": {
      "type": "string"
    },
    "requested_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "ticket_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_hash": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
