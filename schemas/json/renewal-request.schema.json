{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "renewal_request_id",
    "subject_id",
    "requested_by",
    "status"
  ],
  "properties": {
    "renewal_request_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "subject_type": {
      "enum": [
        "agent",
        "blueprint",
        "credential",
        "permission",
        "sponsor_attestation"
      ]
    },
    "requested_by": {
      "type": "string"
    },
    "sponsor_attestation": {
      "type": "object"
    },
    "owner_approval": {
      "type": "object"
    },
    "policy_validation": {
      "type": "object"
    },
    "permission_review": {
      "type": "object"
    },
    "credential_review": {
      "type": "object"
    },
    "risk_review": {
      "type": "object"
    },
    "new_expiration_date": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "requested",
        "in_review",
        "approved",
        "denied",
        "completed"
      ]
    }
  }
}
