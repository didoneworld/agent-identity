{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "subject_type",
    "subject_id",
    "previous_state",
    "new_state"
  ],
  "properties": {
    "subject_type": {
      "enum": [
        "agent",
        "blueprint",
        "credential",
        "permission",
        "sponsor",
        "owner"
      ]
    },
    "subject_id": {
      "type": "string"
    },
    "previous_state": {
      "type": [
        "string",
        "null"
      ]
    },
    "new_state": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "ticket_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requested_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "effective_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "force": {
      "type": "boolean"
    },
    "dry_run": {
      "type": "boolean"
    }
  }
}
