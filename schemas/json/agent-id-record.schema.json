{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/didoneworld/agent-id-protocol/releases/download/v0.2.0/agent-id-record.schema.json",
  "title": "Agent ID Record",
  "type": "object",
  "required": ["agent_id_protocol_version", "agent", "authorization", "governance", "bindings"],
  "properties": {
    "agent_id_protocol_version": {
      "type": "string",
      "const": "0.2.0"
    },
    "agent": {
      "type": "object",
      "required": ["did", "display_name", "owner", "role", "environment", "version", "status", "trust_level", "capabilities"],
      "properties": {
        "did": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:.+$"
        },
        "display_name": {"type": "string"},
        "owner": {"type": "string"},
        "role": {"type": "string"},
        "environment": {"type": "string"},
        "version": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["active", "disabled", "quarantine"]
        },
        "trust_level": {
          "type": "string",
          "enum": ["internal", "curated", "external"]
        },
        "capabilities": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "authorization": {
      "type": "object",
      "required": [
        "mode",
        "subject_context",
        "delegation_proof_formats",
        "scope_reference",
        "expires_at",
        "max_delegation_depth",
        "attenuation_required",
        "human_approval_required"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["autonomous", "delegated", "hybrid"]
        },
        "subject_context": {
          "type": "string",
          "enum": ["first_party", "on_behalf_of_user", "on_behalf_of_team", "multi_party"]
        },
        "delegation_proof_formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "oauth_token_exchange",
              "oidc_identity_assertion",
              "verifiable_credentials",
              "biscuits",
              "macaroons"
            ]
          }
        },
        "scope_reference": {
          "type": ["string", "null"]
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "max_delegation_depth": {
          "type": "integer",
          "minimum": 0
        },
        "attenuation_required": {
          "type": "boolean"
        },
        "human_approval_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": [
        "provisioning",
        "audit_endpoint",
        "status_endpoint",
        "deprovisioning_endpoint",
        "identity_chain_preserved"
      ],
      "properties": {
        "provisioning": {
          "type": "string",
          "enum": ["manual", "scim", "dynamic_client_registration", "internal_iam"]
        },
        "audit_endpoint": {"type": ["string", "null"], "format": "uri"},
        "status_endpoint": {"type": ["string", "null"], "format": "uri"},
        "deprovisioning_endpoint": {"type": ["string", "null"], "format": "uri"},
        "identity_chain_preserved": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "bindings": {
      "type": "object",
      "properties": {
        "a2a": {
          "type": "object",
          "properties": {
            "endpoint_url": {"type": ["string", "null"], "format": "uri"},
            "agent_card_name": {"type": ["string", "null"]}
          },
          "required": ["endpoint_url", "agent_card_name"],
          "additionalProperties": false
        },
        "acp": {
          "type": "object",
          "properties": {
            "endpoint_url": {"type": ["string", "null"], "format": "uri"}
          },
          "required": ["endpoint_url"],
          "additionalProperties": false
        },
        "anp": {
          "type": "object",
          "properties": {
            "did": {"type": ["string", "null"], "pattern": "^did:[a-z0-9]+:.+$"},
            "endpoint_url": {"type": ["string", "null"], "format": "uri"}
          },
          "required": ["did", "endpoint_url"],
          "additionalProperties": false
        }
      },
      "required": ["a2a", "acp", "anp"],
      "additionalProperties": false
    },
    "extensions": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "authorization": {
            "properties": {
              "mode": {"const": "autonomous"}
            },
            "required": ["mode"]
          }
        }
      },
      "then": {
        "properties": {
          "authorization": {
            "properties": {
              "subject_context": {"const": "first_party"}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authorization": {
            "properties": {
              "mode": {"const": "delegated"}
            },
            "required": ["mode"]
          }
        }
      },
      "then": {
        "properties": {
          "authorization": {
            "properties": {
              "subject_context": {
                "enum": ["on_behalf_of_user", "on_behalf_of_team", "multi_party"]
              },
              "scope_reference": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "governance": {
            "properties": {
              "identity_chain_preserved": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authorization": {
            "properties": {
              "mode": {"const": "hybrid"}
            },
            "required": ["mode"]
          }
        }
      },
      "then": {
        "properties": {
          "governance": {
            "properties": {
              "identity_chain_preserved": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "governance": {
            "properties": {
              "identity_chain_preserved": {"const": true}
            },
            "required": ["identity_chain_preserved"]
          }
        }
      },
      "then": {
        "properties": {
          "governance": {
            "properties": {
              "audit_endpoint": {
                "type": "string",
                "format": "uri",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
