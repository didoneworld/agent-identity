{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "credential_id",
    "credential_type",
    "issuer",
    "subject",
    "status"
  ],
  "properties": {
    "credential_id": {
      "type": "string"
    },
    "credential_type": {
      "type": "string"
    },
    "issuer": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "kid": {
      "type": "string"
    },
    "verification_method": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "activated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "revoked_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_rotated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "next_rotation_due_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "rotation_policy_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "issued",
        "active",
        "retiring",
        "revoked",
        "expired",
        "recovered",
        "archived"
      ]
    },
    "revocation_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "grace_period_seconds": {
      "type": "integer",
      "minimum": 0
    }
  }
}
