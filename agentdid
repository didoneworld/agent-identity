#!/usr/bin/env python3
"""Minimal Agent DID lifecycle CLI.

Configure AGENTDID_BASE_URL and AGENTDID_API_KEY, then run commands such as:
  agentdid lifecycle validate <agent_id>
  agentdid blueprint lifecycle disable <blueprint_id>
"""
from __future__ import annotations

import json
import os
import sys
import urllib.request


def request(method: str, path: str, payload: dict | None = None) -> None:
    base = os.environ.get("AGENTDID_BASE_URL", "http://localhost:8000").rstrip("/")
    api_key = os.environ.get("AGENTDID_API_KEY")
    body = None if payload is None else json.dumps(payload).encode()
    headers = {"Content-Type": "application/json"}
    if api_key:
        headers["X-API-Key"] = api_key
    req = urllib.request.Request(base + path, data=body, method=method, headers=headers)
    with urllib.request.urlopen(req) as resp:  # nosec - operator supplied URL
        print(resp.read().decode())


def lifecycle(agent_id: str, action: str) -> None:
    if action == "validate":
        request("POST", f"/v1/agent-records/{agent_id}/validate", {})
    elif action == "audit":
        request("GET", f"/v1/agent-records/{agent_id}/lifecycle-events")
    else:
        request("POST", f"/v1/agent-records/{agent_id}/{action}", {"reason": f"cli {action}", "requested_by": "agentdid-cli"})


def blueprint_lifecycle(blueprint_id: str, action: str) -> None:
    request("POST", f"/v1/blueprints/{blueprint_id}/{action}", {"reason": f"cli {action}", "requested_by": "agentdid-cli"})


def main(argv: list[str]) -> int:
    if len(argv) >= 4 and argv[1] == "lifecycle":
        action, agent_id = argv[2], argv[3]
        allowed = {"validate", "activate", "suspend", "resume", "quarantine", "renew", "rotate-credentials", "deprovision", "audit"}
        if action not in allowed:
            raise SystemExit(f"unsupported lifecycle action: {action}")
        lifecycle(agent_id, action)
        return 0
    if len(argv) >= 5 and argv[1] == "blueprint" and argv[2] == "lifecycle":
        action, blueprint_id = argv[3], argv[4]
        allowed = {"disable", "deprovision-children"}
        if action not in allowed:
            raise SystemExit(f"unsupported blueprint lifecycle action: {action}")
        blueprint_lifecycle(blueprint_id, action)
        return 0
    print(__doc__)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
