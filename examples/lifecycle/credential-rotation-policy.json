{
  "policy_id": "policy-credential-rotation-90d",
  "name": "Credential rotation every 90 days",
  "credential_rotation_days": 90,
  "rotation_grace_period_days": 7,
  "rules": [
    { "if": "credential.next_rotation_due_at <= now", "then": "rotate_credentials" },
    { "if": "old_credential.grace_period_elapsed", "then": "revoke_old_credential" }
  ]
}
